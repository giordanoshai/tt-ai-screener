# ── Data Sources ──────────────────────────────────
FINNHUB_KEY=your_finnhub_api_key_here
FINNHUB_TIER=free                  # free (60 calls/min) | premium (300+ calls/min)

# ── Database ──────────────────────────────────────
DB_PATH=./trading.duckdb

# ── Data Pipeline Tuning ──────────────────────────
NEWS_DAYS=30
# FUNDAMENTALS_STALE_DAYS=7
# NEWS_MOVER_PCT_THRESHOLD=5.0
# NEWS_MOVER_VOLRATIO_THRESHOLD=2.0
# OHLCV_BATCH_SIZE=200

# ── MCP Remote Server ────────────────────────────
# MCP_PORT=8766                     # Streamable HTTP port
# MCP_TOKEN=                        # Auto-generated on first run if empty

# ── AI (可选，推荐通过 Web Settings 页面配置) ──────
# 以下仅在首次初始化数据库时 seed 到 ai_models 表，之后以数据库为准。
# 也可以跳过这里，启动后在 Web 界面 Settings → AI Models 中添加。

# Sentiment (小模型，数据更新时批量打分)
# SENTIMENT_API_BASE=https://api.openai.com/v1
# SENTIMENT_API_KEY=
# SENTIMENT_MODEL=gpt-4o-mini

# Analysis (大模型，skills 分析引擎)
# AI_API_BASE=https://api.openai.com/v1
# AI_API_KEY=
# AI_MODEL=gpt-4o
